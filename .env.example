# ═══════════════════════════════════════════
# tota — Agent Configuration
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════

# Agent Identity
TOTA_NAME=tota
TOTA_OWNER=

# ── LLM Providers ──

# OpenAI (also covers OpenAI-compatible: DeepSeek, Together, etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# DeepSeek (uses dedicated DeepSeek SDK)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# Grok / xAI (OpenAI-compatible API)
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-4

# Ollama Cloud (API key required for ollama.com/v1)
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_BASE_URL=https://ollama.com/v1
OLLAMA_CLOUD_MODEL=gpt-oss:120b

# Ollama Local (no API key required)
OLLAMA_LOCAL_BASE_URL=http://127.0.0.1:11434/api
OLLAMA_LOCAL_MODEL=qwen3.5:2b
OLLAMA_LOCAL_ENABLED=true

# OpenAI Compilations (self-hosted or third-party OpenAI-compatible API)
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_MODEL=
OPENAI_COMPAT_ENABLED=false

# MiMo / Xiaomi (OpenAI-compatible API)
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro

# MiMo Token Plan / Xiaomi (subscription-based)
MIMO_TOKEN_PLAN_API_KEY=
MIMO_TOKEN_PLAN_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_TOKEN_PLAN_MODEL=mimo-v2.5-pro
MIMO_TOKEN_PLAN_ENABLED=false

# NVIDIA NIM (OpenAI-compatible, access hundreds of hosted models)
# Get a key at: https://build.nvidia.com → Account → API Keys
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-super-120b-a12b

# OpenRouter (routes to 300+ models via one API key)
# Get a key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/auto

# Default provider: deepseek | openai | anthropic | grok | ollamaCloud | ollamaLocal | openaiCompat | mimo | mimoTokenPlan | nvidia | openrouter
DEFAULT_PROVIDER=deepseek

# ── Telegram ──
# Get a bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ── Web Search ──
# Choose one or more providers (auto-detected in order: Brave → Serper → Tavily)
# Set WEB_SEARCH_ENABLED=true to enable web search capability

WEB_SEARCH_ENABLED=true
# Provider: brave | serper | tavily | auto (default: auto)
WEB_SEARCH_PROVIDER=auto
# Max results per search (default: 5, max: 10)
WEB_SEARCH_MAX_RESULTS=5

# Brave Search API (free tier: 2000 queries/month)
# Get key at: https://brave.com/search/api/
BRAVE_API_KEY=

# Serper.dev (Google search API, 2500 free queries)
# Get key at: https://serper.dev/
SERPER_API_KEY=

# Tavily AI Search (1000 free searches/month)
# Get key at: https://tavily.com/
TAVILY_API_KEY=

# ── Memory ──
MEMORY_DIR=./memory

# ── Heartbeat ──
HEARTBEAT_INTERVAL_MINUTES=60

# ── Token Budget ──
DAILY_TOKEN_BUDGET=50000

# ── GitHub (optional) ──
# Fine-grained personal access token with repo scope
# Create at: https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=
GITHUB_USERNAME=
GITHUB_EMAIL=tota@github.com
# Default repo for GitHub tools (optional — you can also specify per-call)
GITHUB_DEFAULT_OWNER=
GITHUB_DEFAULT_REPO=

# ─── Google (Calendar + Gmail) ───────────────────────────────────────────────
# Create OAuth credentials (Desktop app) at console.cloud.google.com and add the
# redirect URI http://localhost:8765/oauth2callback. Enable the Calendar/Gmail APIs.
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_GMAIL_CLIENT_ID=
GOOGLE_GMAIL_CLIENT_SECRET=
# Shared fallback used by any Google service that has no service-specific id:
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Google Workspace / company accounts:
#  - Restrict sign-in to a domain (hd= param), e.g. yourcompany.com
GOOGLE_HOSTED_DOMAIN=
#  - Pre-fill the consent account (login_hint=)
GOOGLE_LOGIN_HINT=
#  - Headless domain-wide delegation: service-account key + user to impersonate
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_IMPERSONATE_SUBJECT=
