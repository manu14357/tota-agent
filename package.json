{
  "name": "tota-agent",
  "version": "0.0.4",
  "description": "Soul-driven AI agent with 60+ tools, web search, vision, 11 LLM providers with automatic fallback, browser/desktop/Android automation, MCP plugins, REST API, Second Brain memory, and multi-channel access (CLI, Telegram, WhatsApp, REST API).",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "tota": "dist/index.js",
    "tota-agent": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "ai-agent",
    "cli",
    "telegram",
    "telegram-bot",
    "personal-assistant",
    "soul-driven",
    "token-budget",
    "permissions",
    "scheduler",
    "cron",
    "skill-system",
    "deepseek",
    "openai",
    "anthropic",
    "llm"
  ],
  "author": "manu14357",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manu14357/tota-agent.git"
  },
  "homepage": "https://github.com/manu14357/tota-agent",
  "bugs": {
    "url": "https://github.com/manu14357/tota-agent/issues"
  },
